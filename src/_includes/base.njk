<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}{{ site.siteName }}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.siteDesc }}{% endif %}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ site.siteUrl }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.siteName }}">
  <meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.siteDesc }}{% endif %}">
  <meta property="og:image" content="https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=1200">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  {% include "partials/navbar.njk" %}
  <main>{{ content | safe }}</main>
  {% include "partials/footer.njk" %}
  {% include "partials/cart.njk" %}
  <div class="toast-stack" id="toastStack"></div>
  <a class="wa-float" href="https://wa.me/{{ site.waNumber }}?text=Halo%20{{ site.siteName }}%2C%20saya%20ingin%20konsultasi" target="_blank" title="Chat WhatsApp">
    <i class="bi bi-whatsapp"></i>
  </a>
  <script>
    const SITE_CONFIG = { waNumber: '{{ site.waNumber }}', storeName: '{{ site.siteName }}' };
  </script>
  <script src="/js/cart.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
