<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}{{ site.siteName }} — {{ site.siteDesc }}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.siteDesc }}{% endif %}">
  <meta name="keywords" content="toko laptop, cctv murah, perangkat jaringan, aksesoris wifi, kabel lan, uniq cell">
  <meta name="author" content="{{ site.siteName }}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{ site.siteUrl }}{{ page.url }}">

  <!-- OG -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.siteUrl }}{{ page.url }}">
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}{{ site.siteName }}">
  <meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.siteDesc }}{% endif %}">
  <meta property="og:image" content="https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=1200">
  <meta name="twitter:card" content="summary_large_image">

  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <!-- Global CSS -->
  <link rel="stylesheet" href="/css/main.css">

  {% block head %}{% endblock %}
</head>
<body>

  <!-- NAVBAR -->
  {% include "partials/navbar.njk" %}

  <!-- MAIN CONTENT -->
  <main>
    {% block content %}{% endblock %}
  </main>

  <!-- FOOTER -->
  {% include "partials/footer.njk" %}

  <!-- CART PANEL -->
  {% include "partials/cart.njk" %}

  <!-- TOAST -->
  <div class="toast-stack" id="toastStack"></div>

  <!-- WA Float -->
  <a class="wa-float" href="https://wa.me/{{ site.waNumber }}?text=Halo%20{{ site.siteName }}%2C%20saya%20ingin%20konsultasi%20produk" target="_blank" title="Chat WhatsApp">
    <i class="bi bi-whatsapp"></i>
  </a>

  <!-- Global JS -->
  <script>
    const SITE_CONFIG = {
      waNumber: '{{ site.waNumber }}',
      storeName: '{{ site.siteName }}'
    };
  </script>
  <script src="/js/cart.js"></script>
  <script src="/js/main.js"></script>

  {% block scripts %}{% endblock %}
</body>
</html>
