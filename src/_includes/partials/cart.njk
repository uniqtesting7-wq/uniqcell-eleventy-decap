<div class="cart-overlay" id="cartOverlay"></div>
<div class="cart-panel" id="cartPanel">
  <div class="cart-hdr">
    <div class="cart-hdr-title"><i class="bi bi-bag"></i> Keranjang Belanja</div>
    <button class="cart-close-btn" id="cartClose"><i class="bi bi-x"></i></button>
  </div>
  <div class="cart-body" id="cartBody">
    <div class="cart-empty">
      <i class="bi bi-bag"></i>
      <span>Keranjang kosong</span>
    </div>
  </div>
  <div class="cart-ftr">
    <div class="cart-total-row">
      <span>Total</span>
      <span id="cartTotal">Rp 0</span>
    </div>
    <button class="btn-checkout" id="checkoutBtn" disabled>
      <i class="bi bi-whatsapp"></i> Checkout via WhatsApp
    </button>
    <button class="btn-clear" id="clearBtn" disabled>Kosongkan Keranjang</button>
  </div>
</div>
