---
layout: base.njk
title: "Katalog Produk"
description: "Katalog lengkap laptop, CCTV, dan perangkat jaringan UNIQ CELL."
permalink: /products/
---

<!-- PAGE HEADER -->
<div class="page-header">
  <div class="page-header-inner">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <i class="bi bi-chevron-right" style="font-size:.65rem"></i>
      <span>Produk</span>
    </div>
    <h1>Katalog Produk</h1>
    <p>Temukan laptop, CCTV, dan perangkat jaringan berkualitas terbaik untuk kebutuhan Anda.</p>
    <div class="header-stats">
      <div class="hstat"><i class="bi bi-box-seam"></i> <span id="totalProduk">{{ collections.products | length }} Produk Tersedia</span></div>
      <div class="hstat"><i class="bi bi-shield-check"></i> Garansi Resmi</div>
    </div>
  </div>
</div>

<div class="main-layout">
  <button class="mob-filter-toggle" id="mobFilterToggle">
    <span><i class="bi bi-funnel"></i> &nbsp;Filter &amp; Urutkan</span>
    <i class="bi bi-chevron-down" id="mobFilterIcon"></i>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-card">
      <div class="sidebar-title">Kategori</div>
      <div class="cat-list">
        <div class="cat-item active" data-cat="all">
          <div class="cat-left"><i class="bi bi-grid-3x3-gap"></i> Semua Produk</div>
          <span class="cat-count" id="countAll">{{ collections.products | length }}</span>
        </div>
        <div class="cat-item" data-cat="laptop">
          <div class="cat-left"><i class="bi bi-laptop"></i> Laptop</div>
          <span class="cat-count" id="countLaptop">{{ collections.laptops | length }}</span>
        </div>
        <div class="cat-item" data-cat="cctv">
          <div class="cat-left"><i class="bi bi-camera-video"></i> CCTV</div>
          <span class="cat-count" id="countCctv">{{ collections.cctv | length }}</span>
        </div>
        <div class="cat-item" data-cat="jaringan">
          <div class="cat-left"><i class="bi bi-router"></i> Jaringan</div>
          <span class="cat-count" id="countJaringan">{{ collections.jaringan | length }}</span>
        </div>
      </div>
    </div>
    <div class="sidebar-card">
      <div class="sidebar-title">Rentang Harga</div>
      <div class="price-options">
        <label class="price-opt"><input type="radio" name="price" value="all" checked> Semua Harga</label>
        <label class="price-opt"><input type="radio" name="price" value="0-1000000"> Di bawah Rp 1 jt</label>
        <label class="price-opt"><input type="radio" name="price" value="1000000-5000000"> Rp 1 jt - 5 jt</label>
        <label class="price-opt"><input type="radio" name="price" value="5000000-20000000"> Rp 5 jt - 20 jt</label>
        <label class="price-opt"><input type="radio" name="price" value="20000000-999999999"> Di atas Rp 20 jt</label>
      </div>
    </div>
    <div class="sidebar-card">
      <div class="sidebar-title">Urutkan</div>
      <select class="sort-select" id="sortSelect">
        <option value="default">Default</option>
        <option value="price-asc">Harga: Termurah</option>
        <option value="price-desc">Harga: Termahal</option>
        <option value="name-asc">Nama: A-Z</option>
        <option value="name-desc">Nama: Z-A</option>
      </select>
    </div>
    <button class="btn-reset" id="resetBtn" style="display:none">
      <i class="bi bi-x-circle"></i> Reset Semua Filter
    </button>
  </aside>

  <div class="content-area">
    <div class="toolbar">
      <div class="result-info" id="resultInfo">
        Menampilkan <strong>{{ collections.products | length }}</strong> produk
      </div>
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <div class="search-wrap">
          <i class="bi bi-search search-icon"></i>
          <input class="search-input" id="searchInput" type="text" placeholder="Cari produk...">
          <button class="search-clear" id="searchClear"><i class="bi bi-x"></i></button>
        </div>
        <div class="view-toggle">
          <button class="view-btn active" id="viewGrid" title="Grid"><i class="bi bi-grid-3x3-gap"></i></button>
          <button class="view-btn" id="viewList" title="List"><i class="bi bi-list-ul"></i></button>
        </div>
      </div>
    </div>
    <div class="active-filters" id="activeFilters"></div>
    <div class="prod-grid" id="prodCatalogGrid"></div>
  </div>
</div>

<script>
window.CATALOG_PRODUCTS = [
  {% for product in collections.products %}
  {% set p = product.data %}
  { slug: "{{ p.slug }}", name: "{{ p.title | replace('"', '\\\"')}}", kategori: "{{ p.kategori }}", img: "{{ p.img }}", spec: "{{ p.spec | replace('"', '\\\"')}}", price: {{ p.price }} }{% if not loop.last %},{% endif %}
  {% endfor %}
];
</script>
